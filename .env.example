# OpenAI
OPENAI_API_KEY=
GROQ_API_KEY=

# Model configuration
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.3
DEFAULT_TEMPERATURE=0.0

# App config
APP_ENV=development
APP_PORT=3015
MEBRAIN_SYSTEM_API_URL=http://127.0.0.1:4005

# RAG Configuration
LANGUAGE_DB_PATH=public/language_database/ingl_s.json
DEFAULT_IMAGE_FOLDER=/path/to/images

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=me_english_chat
MONGODB_CONNECT_TIMEOUT_MS=3000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=3000
